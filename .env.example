# ==============================================================================
# Health Monitoring Network - Environment Configuration Example
# Copy this file to '.env' and modify values as required for your environment.
# ==============================================================================

# MQTT Broker Settings
MQTT_BROKER=localhost
MQTT_PORT=1883

# Device Authentication Tokens
# These tokens must match between the sensor simulator and telemetry listener.
SENSOR_001_TOKEN=secure_token_001
SENSOR_002_TOKEN=secure_token_002
SENSOR_003_TOKEN=secure_token_003
SENSOR_004_TOKEN=secure_token_004
SENSOR_005_TOKEN=secure_token_005
